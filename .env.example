# ─── MongoDB ────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pmis

# ─── Flask / Backend (Render) ────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-long-random-string
FLASK_ENV=production
FLASK_DEBUG=0
PORT=5000

# ─── CORS ───────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL(s) — comma-separated, no trailing slash
# e.g. https://pm-internship-engine.vercel.app,https://your-custom-domain.in
ALLOWED_ORIGINS=http://localhost:3000,https://YOUR_VERCEL_APP.vercel.app

# ─── Engine tuning ──────────────────────────────────────────────────────────
RECOMMENDATION_TOP_N=5
MIN_MATCH_SCORE=10
NEAR_MISS_GAP_THRESHOLD=2
