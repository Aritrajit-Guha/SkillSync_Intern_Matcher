# Flask backend
SECRET_KEY=change-me-use-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# CORS
# Local Vite dev server plus deployed frontend URL(s), comma-separated.
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR_VERCEL_APP.vercel.app

# Recommendation tuning
RECOMMENDATION_TOP_N=5
MIN_MATCH_SCORE=10
NEAR_MISS_GAP_THRESHOLD=2

# Optional MongoDB seed helpers
# The Flask API uses backend/data/*.json by default. These are only needed when
# running backend/data/seeds/*.py to populate a MongoDB collection.
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pmis
