# Flask backend
SECRET_KEY=change-me-use-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Internship source
INTERNSHIP_SOURCE=excel
INTERNSHIP_EXCEL_PATH=backend/data/merged_normalized_dataset.xlsx
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1024
# For Gemini 2.5 Flash roadmaps, 0 disables thinking so the full token budget goes to topic output.
GEMINI_THINKING_BUDGET=0
# auto = MongoDB GridFS when MongoDB is reachable, local filesystem otherwise.
# Use mongodb on deployment to keep uploaded files inside MongoDB.
UPLOAD_STORAGE=mongodb

# CORS
# Local Vite dev server plus deployed frontend URL(s), comma-separated.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://YOUR_VERCEL_APP.vercel.app

# Recommendation tuning
RECOMMENDATION_TOP_N=5
MIN_MATCH_SCORE=10
NEAR_MISS_GAP_THRESHOLD=2

# MongoDB for users, applications, roadmap state, and deployed uploads.
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pmis
